#!/usr/bin/env python3
"""Bridge Hyprland workspace state to the Adafruit Macropad LEDs.

Listens on Hyprland's event socket, recomputes per-workspace state on each
relevant event, and pushes frames over the macropad's USB CDC data port.
Also blanks the LEDs while hyprlock is running (lock screen) or the system
is suspending; resume / unlock restores them.

Protocol (line-delimited):
  S<6 digits>  — per-workspace state, each '0' (empty) / '1' (occupied) / '2' (active)
  F<0|1>       — pulse the screenshot key on / off (reflects slurp layer open)
  B<0|1>       — blank all LEDs on / off (reflects lock / suspend)
"""
import json
import os
import selectors
import socket
import subprocess
import sys
import time

WORKSPACES = (1, 2, 3, 4, 5, 6)

RELEVANT_EVENTS = {
    "workspace",
    "focusedmon",
    "activewindow",
    "activewindowv2",
    "openwindow",
    "closewindow",
    "movewindow",
    "movewindowv2",
    "createworkspace",
    "destroyworkspace",
    "moveworkspace",
}

# slurp's layer-shell namespace (default). If you use a screenshot tool
# that wraps slurp under a different name, add its namespace here.
SLURP_LAYER_NAMESPACES = {"selection", "slurp"}

TTY_CANDIDATES = ["/dev/macropad"] + [f"/dev/ttyACM{i}" for i in range(10)]

# `gdbus monitor` emits one signal per line; we only care about
#   /org/freedesktop/login1: org.freedesktop.login1.Manager.PrepareForSleep (true,)
# Session.Lock / Session.Unlock and LockedHint are unreliable: omarchy's
# manual lock hotkey skips loginctl, and hyprlock 0.9 doesn't touch
# LockedHint either, so lock state is detected by polling for hyprlock
# instead.
DBUS_MONITOR_CMD = ["gdbus", "monitor", "--system", "--dest", "org.freedesktop.login1"]
LOCK_POLL_INTERVAL = 2.0  # seconds — how fast we react to hyprlock start/stop


def log(msg):
    print(f"macropad-hyprd: {msg}", file=sys.stderr, flush=True)


def hyprctl_json(what):
    out = subprocess.check_output(["hyprctl", "-j", what], timeout=2)
    return json.loads(out)


def compute_frame():
    monitors = hyprctl_json("monitors")
    workspaces = hyprctl_json("workspaces")
    focused = next((m for m in monitors if m.get("focused")), None)
    active_id = focused.get("activeWorkspace", {}).get("id") if focused else None
    occupied = {w["id"] for w in workspaces if w.get("windows", 0) > 0}
    digits = []
    for wid in WORKSPACES:
        if wid == active_id:
            digits.append("2")
        elif wid in occupied:
            digits.append("1")
        else:
            digits.append("0")
    return ("S" + "".join(digits) + "\n").encode()


class MacropadLink:
    def __init__(self):
        self.fd = None
        self.path = None

    def _open(self):
        for path in TTY_CANDIDATES:
            if os.path.exists(path):
                try:
                    self.fd = open(path, "wb", buffering=0)
                    self.path = path
                    log(f"opened {path}")
                    return True
                except OSError as e:
                    log(f"open {path} failed: {e}")
        return False

    def _close(self):
        if self.fd is not None:
            try:
                self.fd.close()
            except OSError:
                pass
        self.fd = None
        self.path = None

    def write(self, data):
        if self.fd is None and not self._open():
            return
        try:
            self.fd.write(data)
        except OSError as e:
            log(f"write {self.path} failed: {e}")
            self._close()


def connect_event_socket():
    sig = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
    if not sig:
        raise RuntimeError("HYPRLAND_INSTANCE_SIGNATURE not set")
    xdg = os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
    path = f"{xdg}/hypr/{sig}/.socket2.sock"
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.connect(path)
    return sock


def push(link):
    try:
        link.write(compute_frame())
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired, json.JSONDecodeError) as e:
        log(f"hyprctl failed: {e}")


def parse_sleep_line(line):
    """Return True/False on PrepareForSleep transitions, None otherwise."""
    if "PrepareForSleep (true" in line:
        return True
    if "PrepareForSleep (false" in line:
        return False
    return None


def hyprlock_running():
    return subprocess.run(
        ["pgrep", "-x", "hyprlock"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    ).returncode == 0


def spawn_dbus_monitor():
    try:
        return subprocess.Popen(
            DBUS_MONITOR_CMD,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            bufsize=0,
        )
    except (FileNotFoundError, OSError) as e:
        log(f"gdbus monitor unavailable, sleep/lock blanking disabled: {e}")
        return None


def run():
    link = MacropadLink()
    pulse_on = False
    blanked = False
    sleeping = False

    sel = selectors.DefaultSelector()
    dbus = spawn_dbus_monitor()
    if dbus is not None:
        sel.register(dbus.stdout.fileno(), selectors.EVENT_READ, "dbus")
    dbus_buf = b""

    sock = None
    hypr_buf = b""

    def reconcile():
        nonlocal blanked
        desired = sleeping or hyprlock_running()
        if desired == blanked:
            return
        blanked = desired
        if blanked:
            link.write(b"B1\n")
            log("blanked")
        else:
            link.write(b"B0\n")
            push(link)
            log("unblanked")

    while True:
        if sock is None:
            try:
                sock = connect_event_socket()
            except (FileNotFoundError, ConnectionRefusedError, RuntimeError) as e:
                log(f"waiting for Hyprland: {e}")
                time.sleep(2)
                continue
            sel.register(sock.fileno(), selectors.EVENT_READ, "hypr")
            hypr_buf = b""
            reconcile()
            if not blanked:
                push(link)
            link.write(b"F0\n")
            pulse_on = False

        try:
            events = sel.select(timeout=LOCK_POLL_INTERVAL)
        except OSError as e:
            log(f"select error: {e}")
            time.sleep(1)
            continue

        for key, _ in events:
            if key.data == "hypr":
                try:
                    data = sock.recv(4096)
                except OSError as e:
                    log(f"event socket error: {e}")
                    data = b""
                if not data:
                    sel.unregister(sock.fileno())
                    try:
                        sock.close()
                    except OSError:
                        pass
                    sock = None
                    time.sleep(1)
                    break
                hypr_buf += data
                dirty = False
                while b"\n" in hypr_buf:
                    line, hypr_buf = hypr_buf.split(b"\n", 1)
                    event, _, payload = line.partition(b">>")
                    event_s = event.decode(errors="replace")
                    payload_s = payload.decode(errors="replace")
                    if event_s in RELEVANT_EVENTS:
                        dirty = True
                    if event_s == "openlayer" and payload_s in SLURP_LAYER_NAMESPACES:
                        if not pulse_on:
                            link.write(b"F1\n")
                            pulse_on = True
                    elif event_s == "closelayer" and payload_s in SLURP_LAYER_NAMESPACES:
                        if pulse_on:
                            link.write(b"F0\n")
                            pulse_on = False
                if dirty and not blanked:
                    push(link)
            elif key.data == "dbus":
                try:
                    data = os.read(dbus.stdout.fileno(), 4096)
                except OSError as e:
                    log(f"dbus read error: {e}")
                    data = b""
                if not data:
                    log("gdbus monitor exited; restarting")
                    sel.unregister(dbus.stdout.fileno())
                    try:
                        dbus.terminate()
                    except OSError:
                        pass
                    dbus = spawn_dbus_monitor()
                    dbus_buf = b""
                    if dbus is not None:
                        sel.register(dbus.stdout.fileno(), selectors.EVENT_READ, "dbus")
                    continue
                dbus_buf += data
                while b"\n" in dbus_buf:
                    line, dbus_buf = dbus_buf.split(b"\n", 1)
                    state = parse_sleep_line(line.decode(errors="replace"))
                    if state is not None:
                        sleeping = state

        reconcile()


if __name__ == "__main__":
    try:
        run()
    except KeyboardInterrupt:
        pass
